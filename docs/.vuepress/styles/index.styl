// file : docs/.vuepress/styles/index.styl
// ============================================
// 1. 深色模式适配 (针对 Valine)  ✅已修正ID + 强化Chrome表现
// ============================================

// Valine 容器真实 ID：#valine-vuepress-comment
// Chrome 暗色模式下表单控件默认渲染会更“丑”，用 color-scheme 约束它
#valine-vuepress-comment
  color-scheme: light

body.theme-mode-dark #valine-vuepress-comment
  color-scheme: dark

// 覆盖 Valine 评论区文字颜色
body.theme-mode-dark #valine-vuepress-comment .vcontent,
body.theme-mode-dark #valine-vuepress-comment .vcontent p
  color: #e0e0e0 !important

// 评论者昵称颜色
body.theme-mode-dark #valine-vuepress-comment .vhead .vnick
  color: #ffffff !important

// 时间/系统信息/元数据颜色
body.theme-mode-dark #valine-vuepress-comment .vmeta,
body.theme-mode-dark #valine-vuepress-comment .vhead .vtime,
body.theme-mode-dark #valine-vuepress-comment .vhead .vsys
  color: #aaaaaa !important

// 输入框文字颜色
body.theme-mode-dark #valine-vuepress-comment .vctrl,
body.theme-mode-dark #valine-vuepress-comment .vinput,
body.theme-mode-dark #valine-vuepress-comment input.vinput,
body.theme-mode-dark #valine-vuepress-comment textarea.vinput
  color: #e0e0e0 !important

// 输入框背景/边框（让 Chrome 更干净）
body.theme-mode-dark #valine-vuepress-comment .vinput,
body.theme-mode-dark #valine-vuepress-comment input.vinput,
body.theme-mode-dark #valine-vuepress-comment textarea.vinput
  background: rgba(255,255,255,0.06) !important
  border: 1px solid rgba(255,255,255,0.18) !important

// 输入框 Placeholder 颜色
body.theme-mode-dark #valine-vuepress-comment ::placeholder
  color: rgba(224,224,224,0.55) !important

// 提交按钮（暗色）
body.theme-mode-dark #valine-vuepress-comment .vbtn
  background: rgba(255,255,255,0.10) !important
  border: 1px solid rgba(255,255,255,0.20) !important
  color: #e0e0e0 !important

body.theme-mode-dark #valine-vuepress-comment .vbtn:hover
  background: rgba(255,255,255,0.16) !important

// 卡片分隔线更柔和
body.theme-mode-dark #valine-vuepress-comment .vcard
  border-bottom: 1px solid rgba(255,255,255,0.10) !important


// ============================================
// 2. 全局样式微调
// ============================================

// 修正：限制列表链接样式仅作用于文章内容，避免破坏侧边栏
.theme-vdoing-content ul li a
  font-size: 16px
  line-height: 1.8
  display: inline-block
  padding: 2px 0

// 隐藏元素
img.logo
  display: none !important
a.repo-link
  display: none !important
span.iconfont.icon-touxiang
  display: none
.banner-conent
  display: none

// 归档时间右浮动
span.date
  float: right

// 字体设置（正文可用衬线，评论区后面会单独覆盖为更“UI”的字体）
body
  font-family: "Times New Roman", "Noto Serif CJK SC", "Songti SC", "Microsoft YaHei", serif, -apple-system, BlinkMacSystemFont
  line-height: 1.6
  font-size: 16px

h1, h2, h3, h4, h5, h6
  font-family: "Times New Roman", "Noto Serif CJK SC", "Songti SC", "Microsoft YaHei", serif, -apple-system, BlinkMacSystemFont


// ============================================
// 3. 图片样式
// ============================================
.excerpt-wrapper p img
  display: block
  margin: 0 auto

.content-wrapper p img
  max-width: 70% !important
  height: auto
  display: block
  margin: 0 auto
  border-radius: 8px
  @media (max-width: 719px)
    max-width: 100% !important

// 圆角设置
.theme-vdoing-wrapper
  border-radius: 10px !important

.custom-block
  border-radius: 6px

// Banner 高度强制调整
.banner
  min-height: 0px !important


// ✅ 重要：把 18px 只限定在“文章正文”，避免污染 Valine 评论区
.theme-vdoing-content p
  font-size: 18px


// ============================================
// 4. Valine 评论区布局优化 ✅已修正ID + 更稳Flex
// ============================================

// 评论区专用字体：更适合 UI（避免 Times New Roman 让数字/链接/输入框变丑）
#valine-vuepress-comment,
#valine-vuepress-comment input,
#valine-vuepress-comment textarea,
#valine-vuepress-comment button
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
               "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei",
               Arial, sans-serif

// 修正：输入框基础样式 + box-sizing 避免 Chrome/Firefox 计算差异
#valine-vuepress-comment .vheader .vinput
  border: 2px solid #dedede
  border-radius: 5px
  padding-left: 10px
  padding-right: 10px
  box-sizing: border-box

// ✅ 评论内容字号回归（避免被全局 p 字号影响）
#valine-vuepress-comment .vcontent,
#valine-vuepress-comment .vcontent p
  font-size: 16px
  line-height: 1.7

// PC 端：三栏输入更稳（不用 width:32%）
@media (min-width: 720px)
  #valine-vuepress-comment .vheader
    display: flex
    gap: 10px

  #valine-vuepress-comment .vheader .vnick,
  #valine-vuepress-comment .vheader .vmail,
  #valine-vuepress-comment .vheader .vlink
    flex: 1 1 0
    min-width: 0
    margin-left: 0 !important

  #valine-vuepress-comment .vheader .vinput
    width: 100%


// ============================================
// 5. 其他插件样式
// ============================================

// QQ 徽章
.qq
  position: relative
  &::after
    content: "可撩"
    background: $accentColor
    color: #fff
    padding: 0 5px
    border-radius: 10px
    font-size: 12px
    position: absolute
    top: -4px
    right: -35px
    transform: scale(0.85)

// Demo 模块图标
body .vuepress-plugin-demo-block__wrapper
  &,.vuepress-plugin-demo-block__display
    border-color rgba(160,160,160,.3)
  .vuepress-plugin-demo-block__footer:hover
    .vuepress-plugin-demo-block__expand::before
      border-top-color: $accentColor !important
      border-bottom-color: $accentColor !important
    svg
      fill: $accentColor !important

// 全文搜索框
.suggestions
  overflow: auto
  max-height: calc(100vh - 6rem)
  @media (max-width: 719px)
    width: 90vw
    min-width: 90vw !important
    margin-right: -20px
  .highlight
    color: $accentColor
    font-weight: bold


// ============================================
// 6. 视频样式（新增）
// ============================================

.content-wrapper video,
.excerpt-wrapper video
  max-width: 70% !important
  height: auto
  display: block
  margin: 1.5rem auto
  border-radius: 8px
  overflow: hidden
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1)

  @media (max-width: 719px)
    max-width: 100% !important
    border-radius: 6px
    margin: 1rem auto

body.theme-mode-dark
  .content-wrapper video,
  .excerpt-wrapper video
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3)
